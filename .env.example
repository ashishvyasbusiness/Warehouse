# StockBot WMS — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000

# WhatsApp / Meta Cloud API
VERIFY_TOKEN=stockbot123
WHATSAPP_TOKEN=your_meta_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Twilio (alternative to Meta)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: Database URL (for production, replace in-memory store)
DATABASE_URL=postgresql://user:pass@host:5432/stockbot
